{
    "rewrites": [
      {
        "source": "/(moc|don-hang)/:path*",
        "destination": "https://wooden-web-fe.vercel.app/:path*"
      },
      {
        "source": "/pet/:path*",
        "destination": "https://pet-web-fe.vercel.app/pet/:path*"
      },
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ]
  }