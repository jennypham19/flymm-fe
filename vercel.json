{
    "rewrites": [
      {
        "source": "/moc/:path*",
        "destination": "https://wooden-web-fe.vercel.app/:path*"
      },
      {
        "source": "/petz/:path*",
        "destination": "https://pet-web-fe.vercel.app/:path*"
      },
      {
        "source": "/ks/:path*",
        "destination": "https://management-clean-hotel.vercel.app/:path*"
      },
      {
        "source": "/(.*)",
        "destination": "/index.html"
      }
    ]
  }